# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#
# Validation: all vars are validated with Zod at startup.
# If a required var is missing or invalid, the app throws on boot.
# Add new vars to: lib/config/env.server.ts (secrets) or lib/config/env.client.ts (public)

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Example: Database (add when replacing in-memory adapters)
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ------------------------------------------------------------------------------
# Example: External API (server-side only — no NEXT_PUBLIC_ prefix)
# ------------------------------------------------------------------------------
# API_SECRET_KEY=your-secret-key
